BOT_TOKEN=123456:admin_bot_token

# Существующий экспорт/сессия Telegram-аккаунта.
ACCOUNT_DIR=Данные аккаунта Казахстан
ACCOUNT_JSON=
SESSION_NAME=

# Запасной вариант, если ACCOUNT_JSON не содержит api_id/api_hash.
API_ID=
API_HASH=

# SOCKS5-прокси можно указать здесь или в Прокси.txt.
# Поддерживаемые примеры:
# socks5://user:pass@host:port
# user:pass@host:port
# host:port:user:pass
# host:port
PROXY=
PROXY_FILE=Прокси.txt

DB_PATH=data/userbot_parser.sqlite3
EXPORT_DIR=exports
LOG_LEVEL=INFO

# Время ежедневного автопарсинга в локальном часовом поясе сервера.
AUTO_PARSE_TIME=03:00

# Антибан-задержки из ТЗ.
REQUEST_DELAY_MIN=2
REQUEST_DELAY_MAX=5
CHAT_DELAY_MIN=300
CHAT_DELAY_MAX=600
JOIN_DELAY_SECONDS=900
